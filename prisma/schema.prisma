// QR Tanki Database Schema - Minimal working version
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User roles for the system
enum UserRole {
  USER
  CLEANER
  ADMIN
}

// Cleaning types
enum CleaningType {
  BASIC
  DEEP
  EMERGENCY
}

// Payment status
enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// Task status
enum TaskStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Main user model with role-based access
model User {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String
  phone             String?
  role              UserRole @default(USER)
  avatar            String?
  isVerified        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relationships
  tanks             Tank[]
  cleaningRequests  CleaningRequest[]
  feedbacks         Feedback[]
  payments          Payment[]
  cleaner           Cleaner?
  emergencyRequests EmergencyRequest[]

  @@map("users")
}

// Cleaner profile with additional fields
model Cleaner {
  id                String   @id @default(cuid())
  userId            String   @unique
  experience        String?  // Years of experience
  serviceArea       String?  // Geographic area they serve
  rating            Float?   @default(0)
  totalJobs         Int      @default(0)
  isAvailable       Boolean  @default(true)
  bio               String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relationships
  user              User              @relation(fields: [userId], references: [id])
  cleaningRecords   CleaningRecord[]
  cleaningRequests  CleaningRequest[]
  emergencyRequests EmergencyRequest[]

  @@map("cleaners")
}

// Tank information
model Tank {
  id                String   @id @default(cuid())
  userId            String
  name              String   // Tank identifier
  type              String   // Overhead, underground, etc.
  capacity          String?  // Liters
  location          String   // Address/landmark
  installationDate  DateTime?
  lastCleanedDate   DateTime?
  nextDueDate       DateTime?
  hygieneScore      Float?   @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relationships
  user              User              @relation(fields: [userId], references: [id])
  cleaningRecords   CleaningRecord[]
  cleaningRequests  CleaningRequest[]
  emergencyRequests EmergencyRequest[]

  @@map("tanks")
}

// Cleaning requests by users
model CleaningRequest {
  id                String       @id @default(cuid())
  userId            String
  tankId            String
  cleanerId         String?
  cleaningType      CleaningType
  requestedDate     DateTime
  scheduledDate     DateTime?
  preferredTime     String?
  notes             String?
  status            TaskStatus   @default(PENDING)
  urgencyLevel      Int          @default(1) // 1-5 scale
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Relationships
  user              User              @relation(fields: [userId], references: [id])
  tank              Tank              @relation(fields: [tankId], references: [id])
  cleaner           Cleaner?          @relation(fields: [cleanerId], references: [id])
  cleaningRecord    CleaningRecord?

  @@map("cleaning_requests")
}

// Actual cleaning records
model CleaningRecord {
  id                String       @id @default(cuid())
  tankId            String
  cleanerId         String
  requestId         String?      @unique
  cleaningType      CleaningType
  cleanedAt         DateTime
  duration          Int?         // Minutes
  beforePhotos      String?      // JSON string of photo URLs
  afterPhotos       String?      // JSON string of photo URLs
  notes             String?
  hygieneScore      Float?       @default(0)
  isVerified        Boolean      @default(false)
  verifiedBy        String?      // Admin ID
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Relationships
  tank              Tank              @relation(fields: [tankId], references: [id])
  cleaner           Cleaner           @relation(fields: [cleanerId], references: [id])
  request           CleaningRequest?  @relation(fields: [requestId], references: [id])
  feedbacks         Feedback[]

  @@map("cleaning_records")
}

// Payment tracking
model Payment {
  id                String         @id @default(cuid())
  userId            String
  amount            Float
  type              String         // "QR_GENERATION", "SUBSCRIPTION", "CLEANING"
  status            PaymentStatus  @default(PENDING)
  paymentMethod     String?        // "UPI", "CARD", "CASH"
  transactionId     String?        @unique
  paidAt            DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Relationships
  user              User           @relation(fields: [userId], references: [id])

  @@map("payments")
}

// Feedback and ratings
model Feedback {
  id                String   @id @default(cuid())
  userId            String
  cleaningRecordId  String
  rating            Int      // 1-5 stars
  comment           String?
  isPublic          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relationships
  user              User           @relation(fields: [userId], references: [id])
  cleaningRecord    CleaningRecord @relation(fields: [cleaningRecordId], references: [id])

  @@map("feedbacks")
}

// Emergency Service Requests
model EmergencyRequest {
  id                String   @id @default(cuid())
  userId            String
  tankId            String?
  contactName       String
  contactPhone      String
  contactEmail      String
  address           String
  urgencyLevel      String   @default("HIGH") // LOW, MEDIUM, HIGH, CRITICAL
  issueDescription   String
  requestedAt        DateTime @default(now())
  respondedAt        DateTime?
  assignedCleanerId  String?
  estimatedArrival   DateTime?
  status            String   @default("REQUESTED") // REQUESTED, ASSIGNED, IN_PROGRESS, COMPLETED, CANCELLED
  priorityFee       Float    @default(0) // Additional fee for emergency
  totalCost         Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relationships
  user           User     @relation(fields: [userId], references: [id])
  tank           Tank?    @relation(fields: [tankId], references: [id])
  assignedCleaner Cleaner? @relation(fields: [assignedCleanerId], references: [id])

  @@map("emergency_requests")
}